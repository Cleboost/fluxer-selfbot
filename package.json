{
  "name": "fluxer-selfbot",
  "version": "0.0.2",
  "packageManager": "bun@1.3.9",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo run build",
    "build:selfbot": "bun build ./packages/fluxer-core/src/index.ts --outfile ./dist/index.js --target node --bundle --minify",
    "build:types": "bunx dts-bundle-generator -o ./dist/index.d.ts ./packages/fluxer-core/src/index.ts --no-check",
    "build:prod": "bun run build:selfbot && bun run build:types"
  },
  "devDependencies": {
    "@fluxerjs/builders": "workspace:*",
    "@fluxerjs/collection": "workspace:*",
    "@fluxerjs/core": "workspace:*",
    "@fluxerjs/rest": "workspace:*",
    "@fluxerjs/types": "workspace:*",
    "@fluxerjs/util": "workspace:*",
    "@fluxerjs/voice": "workspace:*",
    "@fluxerjs/ws": "workspace:*",
    "dotenv": "^17.3.1",
    "globals": "^17.3.0",
    "lint-staged": "^16.2.7",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "overrides": {
    "tar": ">=7.5.8",
    "minimatch": ">=10.2.1"
  },
  "workspaces": [
    "packages/*",
    "examples",
    "apps/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Cleboost/fluxer-selfbot.git"
  },
  "bugs": "https://github.com/Cleboost/fluxer-selfbot/issues"
}
