{
  "name": "@fluxerjs/docgen",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node --bundle && bun build ./src/index.ts --outfile ./dist/index.mjs --target node --bundle && bunx tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "doctrine": "^3.0.0",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@types/doctrine": "^0.0.9",
    "@types/node": "^20.0.0",
    "typescript": "^5.6.0"
  }
}
