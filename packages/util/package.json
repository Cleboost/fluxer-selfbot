{
  "name": "@fluxerjs/util",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.2.2",
  "description": "Shared utilities for @fluxerjs/core",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cleboost/fluxer-selfbot.git",
    "directory": "packages/util"
  },
  "bugs": "https://github.com/Cleboost/fluxer-selfbot/issues",
  "keywords": [
    "fluxer",
    "util",
    "snowflake",
    "bitfield"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@fluxerjs/types": "workspace:*"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node --bundle && bun build ./src/index.ts --outfile ./dist/index.mjs --target node --bundle && bunx tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
