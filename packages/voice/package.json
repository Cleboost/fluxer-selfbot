{
  "name": "@fluxerjs/voice",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.2.2",
  "description": "Voice support for Fluxer bots",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cleboost/fluxer-selfbot.git",
    "directory": "packages/voice"
  },
  "bugs": "https://github.com/Cleboost/fluxer-selfbot/issues",
  "keywords": [
    "fluxer",
    "voice",
    "audio",
    "livekit"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target node --bundle --external '*' && bun build ./src/index.ts --outfile ./dist/index.mjs --target node --bundle --external '*' && bunx tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@fluxerjs/collection": "workspace:*",
    "@fluxerjs/core": "workspace:*",
    "@fluxerjs/types": "workspace:*",
    "@livekit/rtc-node": "^0.13.24",
    "mp4box": "^0.5.2",
    "opus-decoder": "^0.7.0",
    "prism-media": "^1.3.5",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "optionalDependencies": {
    "livekit-server-sdk": "^2.15.0",
    "node-webcodecs": "^1.0.0"
  }
}
